# Point at a real Postgres for production; leave unset for local PGlite.
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# Absolute dir for the embedded PGlite store (local dev only).
PGLITE_DIR=/abs/path/to/tester-huester/.pglite
# Shared password gate for the dashboard (optional; unset = open on localhost).
# DASH_PASSWORD=changeme
