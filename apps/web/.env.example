# tester-huester / @th/web — runtime environment
# Copy to .env (or set via docker-compose / the process manager) and adjust.
# Every value below has a working default in code, so a bare dev run needs none of them.

# SQLite database file (Node 24 built-in node:sqlite).
# Default: repo-root th.db. In Docker this points at the persistent volume.
SQLITE_FILE=/data/th.db

# Directory for runtime-written blobs (screenshots + rrweb replay JSON).
# Default: <cwd>/.data/uploads. In Docker this lives on the same persistent volume.
UPLOAD_DIR=/data/uploads

# Password gating the dashboard (triage UI). Required in production — set a strong value.
# Consumed by docker-compose via ${DASH_PASSWORD}; keep it out of version control.
DASH_PASSWORD=change-me

# --- Extension build (NOT read by @th/web) -------------------------------------
# The Chrome extension's collector URL. Today the extension reads it at runtime from
# its popup config (default http://localhost:4319), so no build-time env is wired yet.
# For a prod build the intended override is (see DEPLOY.md, step C):
#   VITE_TH_COLLECTOR=https://qa.ihor.work
